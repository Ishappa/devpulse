# ───────────────────────────────────────────────────────────────────────────
# DevPulse environment variables. Copy to `.env.local` and fill in.
# Never commit real secrets. All values below are placeholders.
# ───────────────────────────────────────────────────────────────────────────

# ── Database (Supabase Postgres) ────────────────────────────────────────────
# Pooled connection (PgBouncer, transaction mode) — used by the app at runtime.
DATABASE_URL="postgresql://user:pass@host:6543/postgres?pgbouncer=true&sslmode=require"
# Direct connection — used by drizzle-kit for migrations only (no pooler).
DATABASE_URL_DIRECT="postgresql://user:pass@host:5432/postgres?sslmode=require"

# ── Upstash Redis (cache, rate limiting, leaderboard) ───────────────────────
UPSTASH_REDIS_REST_URL="https://your-db.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-rest-token"

# ── Upstash QStash (ingest job queue) ───────────────────────────────────────
QSTASH_URL="https://qstash.upstash.io"
QSTASH_TOKEN="your-qstash-token"
QSTASH_CURRENT_SIGNING_KEY="sig_..."
QSTASH_NEXT_SIGNING_KEY="sig_..."

# ── Auth (NextAuth / Auth.js v5 + GitHub OAuth) ─────────────────────────────
# Generate: `openssl rand -base64 32`
AUTH_SECRET="generate-a-32-byte-secret"
AUTH_GITHUB_ID="your-github-oauth-app-client-id"
AUTH_GITHUB_SECRET="your-github-oauth-app-client-secret"
# In production set to your deployed URL; locally omit or use http://localhost:3000
# AUTH_URL="https://devpulse.app"

# ── GitHub API (ingest) ─────────────────────────────────────────────────────
# A PAT (classic, no scopes needed for public data) lifts the rate limit to 5000/hr.
GITHUB_TOKEN="ghp_..."

# ── Cron / ingest protection ────────────────────────────────────────────────
# Shared secret so /api/cron/ingest can only be triggered by Vercel Cron.
CRON_SECRET="generate-a-random-secret"

# ── Observability (optional in dev) ─────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN=""
